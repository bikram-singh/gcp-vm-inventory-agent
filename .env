# ── Gemini / ADK ─────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=AQ.xxxxxxxxxxxxxxxxxxxxxx

# ── Slack (optional) ─────────────────────────────────────────────────────────
# Create a Bot token at: https://api.slack.com/apps → OAuth & Permissions
# Required scopes: chat:write, files:write
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=Cxxxxxxxxxx

# ── GCP Auth ─────────────────────────────────────────────────────────────────
# Run this once before starting the agent:
#   gcloud auth application-default login
# No env var needed — ADC is picked up automatically.
